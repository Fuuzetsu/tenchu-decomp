#!/usr/bin/env bash
set -e

# Compile the Shake build driver directly with the devShell's GHC (which has
# shake/aeson/uuid/hashable baked into its package DB via ghcWithPackages), then
# run it. No cabal / Hackage / network needed — works offline on a fresh
# checkout. Build.hs chdirs to the project root itself (via .project.root), so
# it can be invoked from anywhere inside the tree.
root=$(dirname "$(readlink -f "$0")")
outdir="$root/shake/dist-direct"
src="$root/shake/src/Build.hs"
bin="$outdir/Build"
mkdir -p "$outdir"

# Only invoke ghc when the driver is actually stale. `ghc --make` is incremental
# and would exit quickly, but it is still a heavyweight process (and several
# execve calls) on every single ./Build — and tools like matchdiff.py call
# ./Build once per function, hundreds of times per sweep. Compare against both
# the source and this wrapper (whose ghc flags are part of the recipe).
if [ ! -x "$bin" ] || [ "$src" -nt "$bin" ] || [ "$(readlink -f "$0")" -nt "$bin" ]; then
  ghc -O2 -threaded -rtsopts --make \
      -outputdir "$outdir" \
      -o "$bin" \
      "$src"
fi

exec "$bin" "$@"
