 tests/end_to_end/weird-asm/test-out.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/tests/end_to_end/weird-asm/test-out.c b/tests/end_to_end/weird-asm/test-out.c
index a64e891..41fa94a 100644
--- a/tests/end_to_end/weird-asm/test-out.c
+++ b/tests/end_to_end/weird-asm/test-out.c
@@ -1,5 +1,4 @@
-Warning: missing "jr $ra" in last block of test (jumptarget_label).
-
+/* Warning: missing "jr $ra" in last block of test (jumptarget_label). */
 extern s32 more special;
 static s16 special !@#$%^chars[2] = { 0, 0x1234 };  /* const */
 
