+}
diff --git a/tests/end_to_end/psx-unaligned-load/psyq-o2.s b/tests/end_to_end/psx-unaligned-load/psyq-o2.s
new file mode 100644
index 0000000..1a78ccd
--- /dev/null
+++ b/tests/end_to_end/psx-unaligned-load/psyq-o2.s
@@ -0,0 +1,9 @@
+.set noat
+.set noreorder
+
+glabel test
+    /* lwr before lwl — PSX LE unaligned load pattern */
+    lwr  $v0, 1($a0)
+    lwl  $v0, 4($a0)
+    jr   $ra
+     nop
