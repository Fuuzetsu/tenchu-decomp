 m2c/evaluate.py                               | 37 +++++++++++++++++--
 m2c/translate.py                              | 16 ++++++++
 tests/end_to_end/psx-unaligned-load/orig.c    |  9 +++++
 .../psx-unaligned-load/psyq-o2-flags.txt      |  1 +
 .../psx-unaligned-load/psyq-o2-out.c          |  3 ++
 tests/end_to_end/psx-unaligned-load/psyq-o2.s |  9 +++++
 6 files changed, 71 insertions(+), 4 deletions(-)
