+sw    $ra, 0x1c($sp)
+sw    $a0, 0x10($sp)
+bgez  $a1, .L_merge
+sw    $a2, 0x14($sp)
+addiu $a1, $a1, 1
+.L_merge:
+addiu $a0, $a1, 2
+addiu $a1, $zero, 3
+addiu $a2, $zero, 4
+jal   foo
+addiu $a3, $zero, 5
+lw    $ra, 0x1c($sp)
+addiu $sp, $sp, 0x20
+jr    $ra
+move  $v0, $zero
